# OpenAI 兼容的 API 配置（支持 OpenAI / DeepSeek / 其他兼容服务）
OPENAI_API_KEY=sk-xxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1

# 模型选择（LangChain 模型标识符格式: provider:model）
AUTOPS_MODEL=openai:gpt-4o-mini

# 也可使用 Anthropic / Google 等模型
# AUTOPS_MODEL=anthropic:claude-sonnet-4-20250514
# AUTOPS_MODEL=google_genai:gemini-2.0-flash

# Agent 运行参数
AUTOPS_MAX_ITERATIONS=15
AUTOPS_SHELL_TIMEOUT=30
